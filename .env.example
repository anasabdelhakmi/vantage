# Base URL of the Vantage backend HTTP API.
# Leave EMPTY to use the built-in mock agent (great for demos with no backend running).
# Example for a locally running FastAPI wrapper:
#   VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Jitsi Meet server for the "Call a doctor" video call.
# Defaults to the free public server meet.jit.si (fine for demos). For anything
# real, self-host Jitsi (Docker) and point this at your own domain, e.g.
#   VITE_JITSI_DOMAIN=meet.yourclinic.org
VITE_JITSI_DOMAIN=
