# Copy this file to ".env" and fill in real values, OR export these in your shell.
# The app runs fine with NONE of these set (mock mode).

# Which brain to run the agent on (openai | aiand | kimi | nosana | mock; blank = auto-detect).
LLM_PROVIDER=

# Live outbreak signals (real Oxylabs + LLM) vs instant deterministic mock. true|false.
USE_LIVE_SIGNALS=true

# The on-call doctor's FIXED Jitsi video room for escalations. Keep it open on
# your phone to always be reachable. Keep it unguessable; no patient data in it.
DOCTOR_ROOM=vantage-oncall-changeme

# Kimi — the agent brain (https://platform.kimi.ai)
# NOTE: kimi-k2 was discontinued 2026-05-25; default is now kimi-k3.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k3

# OpenAI (ChatGPT) — the agent brain (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Nosana — host the model yourself (https://deploy.nosana.com)
NOSANA_BASE_URL=

# Oxylabs — outbreak/weather signals. Set EITHER product (Web Scraper API preferred).
# Web Scraper API — JS rendering, reaches official sources. https://developers.oxylabs.io
OXYLABS_SCRAPER_USERNAME=
OXYLABS_SCRAPER_PASSWORD=
# Residential Proxy — raw HTML, fast for news feeds. Country in the username
# (e.g. customer-<user>-cc-US). https://oxylabs.io/products/residential-proxy-pool
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_PROXY=pr.oxylabs.io:7777

# ai& — bulk offline safety testing (OpenAI-compatible). https://docs.aiand.com
AIAND_API_KEY=
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=openai/gpt-oss-120b

# Daytona — secure sandbox for running the agent (https://www.daytona.io)
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
