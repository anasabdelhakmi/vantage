# Copy this file to ".env" and fill in real values, OR export these in your shell.
# The app runs fine with NONE of these set (mock mode).

# Kimi — the agent brain (https://platform.moonshot.ai)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2

# Nosana — host the model yourself (https://deploy.nosana.com)
NOSANA_BASE_URL=

# Oxylabs — outbreak/weather signals
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Doubleword — bulk offline testing
DOUBLEWORD_API_KEY=
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1
